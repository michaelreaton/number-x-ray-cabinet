prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: Number X-Ray Shared
Description: Native Number X-Ray shared arbitrary-precision research core
Version: @PROJECT_VERSION@
Cflags: -I${includedir}
Libs: -L${libdir} -lnumber_xray
Libs.private: -lgmp
