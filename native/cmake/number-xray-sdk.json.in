{
  "schemaVersion": 1,
  "name": "number-xray",
  "version": "@PROJECT_VERSION@",
  "description": "Native Number X-Ray arbitrary-precision research core",
  "language": "C11",
  "headers": {
    "public": "number_xray.h",
    "compatibility": "xray_workbench.h",
    "includeDir": "@CMAKE_INSTALL_INCLUDEDIR@"
  },
  "apiDocumentation": {
    "format": "doxygen-comments",
    "entryHeader": "number_xray.h",
    "functionReferenceHeader": "xray_workbench.h",
    "catalog": "@XRAY_API_CATALOG_FILE@",
    "catalogSchemaVersion": 1,
    "coverage": "all exported XRAY_API functions"
  },
  "abi": {
    "version": 1,
    "versionFunction": "xray_version",
    "abiVersionFunction": "xray_abi_version"
  },
  "bignumBackend": {
    "name": "@XRAY_GMP_BACKEND_NAME@",
    "library": "@XRAY_GMP_LIBRARY_NAME@",
    "nameFunction": "xray_bignum_backend_name",
    "versionFunction": "xray_bignum_backend_version",
    "libraryFunction": "xray_bignum_backend_library"
  },
  "libraries": {
    "core": {
      "name": "xray_core",
      "kind": "static",
      "libDir": "@CMAKE_INSTALL_LIBDIR@",
      "cmakeTarget": "NumberXRay::core",
      "pkgConfig": "number-xray"
    }@XRAY_SDK_SHARED_LIBRARY_JSON@
  },
  "cmake": {
    "package": "NumberXRay",
    "configFile": "@NumberXRay_INSTALL_CMAKEDIR@/NumberXRayConfig.cmake"
  },
  "dependencies": [
    {
      "name": "GMP or MPIR",
      "header": "gmp.h",
      "cmakeTarget": "GMP::GMP",
      "required": true
    }
  ],
  "memory": {
    "allocator": "system malloc/free",
    "freeFunction": "xray_free",
    "callerFrees": true
  }
}
