prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: Number X-Ray
Description: Native Number X-Ray arbitrary-precision research core
Version: @PROJECT_VERSION@
Cflags: -I${includedir}
Libs: -L${libdir} -lxray_core
Libs.private: -lgmp
